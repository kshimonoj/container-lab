# CX-CLAB MCP server config. Copy to .env and set a real MCP_TOKEN.
# .env is gitignored; .env.example is committed.

# Bind address / port. 0.0.0.0 so the Macbook (same LAN) can reach it.
# Keep PORT off 8888 (the GUI backend).
MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_PATH=/mcp

# Single fixed bearer token. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# The SAME value must go in claude_desktop_config.json (Authorization header).
MCP_TOKEN=replace-with-a-long-random-token
