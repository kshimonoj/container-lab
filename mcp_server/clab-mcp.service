# clab-mcp server — systemd unit (sample).
#
# Install (run as the kshimono user / with sudo as noted):
#   sudo cp ~/work/container-lab/mcp_server/clab-mcp.service \
#           /etc/systemd/system/clab-mcp.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now clab-mcp
#   systemctl status clab-mcp
#
# This service is INDEPENDENT of the GUI (clab-gui). Restarting one does not
# affect the other. It needs docker (to inspect/SSH the nodes) so it orders
# after docker.service, but does not pull it in.

[Unit]
Description=clab-mcp server (AOS-CX / vJunos over Streamable HTTP)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=kshimono
Group=kshimono
WorkingDirectory=/home/kshimono/work/container-lab/mcp_server
# Reuses the Phase-07 venv (junos-eznc + ncclient + paramiko) with fastmcp/requests added.
ExecStart=/home/kshimono/work/api-test-venv/bin/python /home/kshimono/work/container-lab/mcp_server/server.py
# Config (bind/port/token) is read from mcp_server/.env by the process itself.
Restart=on-failure
RestartSec=5
# Logs go to the journal: journalctl -u clab-mcp -f
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
